{
  "name": "@medusajs/auth-google",
  "version": "3.0.0",
  "description": "Google OAuth authentication provider for Medusa",
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/medusajs/medusa.git",
    "directory": "packages/modules/providers/auth-google"
  },
  "bugs": {
    "url": "https://github.com/medusajs/medusa/issues"
  },
  "files": [
    "dist",
    "!dist/**/__tests__",
    "!dist/**/__mocks__",
    "!dist/**/__fixtures__"
  ],
  "engines": {
    "node": ">=20"
  },
  "author": "Medusa",
  "license": "MIT",
  "scripts": {
    "test": "../../../../node_modules/.bin/jest --passWithNoTests src",
    "test:integration": "../../../../node_modules/.bin/jest --passWithNoTests --forceExit --testPathPattern=\"integration-tests/__tests__/.*\\.spec\\.ts\"",
    "build": "yarn run -T rimraf dist && yarn run -T tsc --build",
    "watch": "yarn run -T tsc --watch"
  },
  "devDependencies": {
    "@medusajs/framework": "3.0.0"
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.1.0"
  },
  "peerDependencies": {
    "@medusajs/framework": "3.0.0"
  },
  "keywords": [
    "medusa-provider",
    "medusa-provider-auth-google"
  ]
}
